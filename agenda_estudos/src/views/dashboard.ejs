<!DOCTYPE html>
<html>
<head>
<title>Dashboard</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-dark bg-primary">
<div class="container-fluid">
<span class="navbar-brand">Agenda de Estudos</span>

<div>
<span class="text-white me-3">
Olá, <%= user.nome %>
</span>

<a href="/logout" class="btn btn-light btn-sm">
Sair
</a>
</div>
</div>
</nav>

<div class="container mt-4">

<h3>Nova Tarefa</h3>

<form action="/nova-tarefa" method="POST">

<input class="form-control mb-2" name="titulo" placeholder="Título">

<textarea class="form-control mb-2" name="descricao" placeholder="Descrição"></textarea>

<input class="form-control mb-2" type="date" name="data_entrega">

<button class="btn btn-primary">
Adicionar
</button>

</form>

<hr>

<table class="table table-bordered">

<thead>
<tr>
<th>Título</th>
<th>Status</th>
<th>Tempo</th>
<th>Ações</th>
</tr>
</thead>

<tbody>

<% tarefas.forEach(tarefa => { %>

<tr>

<td>
<strong><%= tarefa.titulo %></strong><br>
<%= tarefa.descricao %>
</td>

<td>

<% if(tarefa.status === 'running'){ %>

<span class="badge bg-success">
Em andamento
</span>

<% } else if(tarefa.status === 'paused'){ %>

<span class="badge bg-warning text-dark">
Pausada
</span>

<% } else if(tarefa.status === 'completed'){ %>

<span class="badge bg-secondary">
Concluída
</span>

<% } else { %>

<span class="badge bg-info text-dark">
Pendente
</span>

<% } %>

</td>

<td>
<strong>
<%= tarefa.tempo_formatado %>
</strong>
</td>

<td>

<% if(tarefa.status === 'pending'){ %>

<form action="/iniciar/<%= tarefa.id %>" method="POST" style="display:inline">
<button class="btn btn-success btn-sm">▶</button>
</form>

<% } %>

<% if(tarefa.status === 'running'){ %>

<form action="/pausar/<%= tarefa.id %>" method="POST" style="display:inline">
<button class="btn btn-warning btn-sm">⏸</button>
</form>

<% } %>

<% if(tarefa.status === 'paused'){ %>

<form action="/retomar/<%= tarefa.id %>" method="POST" style="display:inline">
<button class="btn btn-info btn-sm">🔁</button>
</form>

<% } %>

<% if(tarefa.status !== 'completed'){ %>

<form action="/concluir/<%= tarefa.id %>" method="POST" style="display:inline">
<button class="btn btn-primary btn-sm">✅</button>
</form>

<% } %>

<form action="/excluir/<%= tarefa.id %>" method="POST" style="display:inline">
<button class="btn btn-danger btn-sm">🗑</button>
</form>

</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</body>
</html>